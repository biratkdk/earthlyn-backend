PORT=5000
NODE_ENV=development
AUTH_JWT_SECRET=change_me_to_a_long_random_value
CORS_ORIGINS=http://localhost:3005
LOG_LEVEL=info

# Optional PostgreSQL connection. Leave blank to run with in-memory fallback data.
DATABASE_URL=

# Recommended: Gemini-backed upload scans, similar to the reference backend.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: enables OpenAI-backed recommendation copy when available.
OPENAI_API_KEY=your_openai_api_key_here

# Optional Google Vision text fallback.
GOOGLE_CLOUD_API_KEY=your_google_vision_api_key_here
GOOGLE_BOOKS_COUNTRY=US
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id

# Local OCR fallback for /api/scan. Set to 0 to disable it.
UPLOAD_LOCAL_OCR_ENABLED=1
