# Backend runtime
NODE_ENV=production
AUTH_JWT_SECRET=replace-with-a-strong-random-secret
AUTH_TOKEN_TTL=7d
AUTH_COOKIE_SAMESITE=lax

# For local Postgres using the Windows install/user supplied in this project:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/shelfscanner
# Or set PG* variables instead:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=shelfscanner
PGSSL_REJECT_UNAUTHORIZED=true

# Frontend/API origins
FRONTEND_URL=https://your-vercel-domain.vercel.app
CORS_ORIGINS=https://your-vercel-domain.vercel.app
CSP_CONNECT_SRC=https://your-vercel-domain.vercel.app
VITE_API_BASE_URL=

# Providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_BOOKS_API_KEY=
GOOGLE_CLOUD_API_KEY=
GOOGLE_BOOKS_COUNTRY=US

# Limits/timeouts
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb
GOODREADS_IMPORT_LIMIT=8mb
GOODREADS_IMPORT_MAX_BYTES=8388608
GOODREADS_IMPORT_MAX_ROWS=1000
GOOGLE_BOOKS_TIMEOUT_MS=8000
GOOGLE_BOOKS_CACHE_TTL_MS=600000
GOOGLE_BOOKS_CACHE_MAX=250
GEMINI_SCAN_TOTAL_TIMEOUT_MS=55000
GEMINI_SCAN_MODEL_TIMEOUT_MS=12000
