{
  "buildCommand": "npm ci --prefix packages/backend && npm ci --prefix packages/frontend && npm run build --prefix packages/frontend",
  "outputDirectory": "packages/frontend/dist",
  "installCommand": "npm ci",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": [
        "packages/backend/src/**",
        "packages/frontend/dist/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
